# ============================================================================
# 评委大模型配置 (Evaluator Model Configuration)
# ============================================================================
# 支持 OpenAI 格式的 API
# 用于自动评分本地模型的输出质量

EVALUATOR_BASE_URL=http://127.0.0.1:4000
EVALUATOR_API_KEY=your_evaluator_api_key_here
EVALUATOR_MODEL_GEM=gemini-2.0-flash-001
EVALUATOR_MODEL_OPUS=claude-3-5-sonnet-20241022
EVALUATOR_MODEL_GPT=gpt-4o
EVALUATOR_MODEL_TOP2=qwen3.5-plus
EVALUATOR_MODEL_TOP=top

# TOP2 评委专用 Qwen 配置
EVALUATOR_TOP2_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
EVALUATOR_TOP2_API_KEY=your_qwen_api_key_here

# ============================================================================
# 本地模型配置 (Local Model Configuration)
# ============================================================================
# 默认使用的模型 API 配置
# 可以是本地 llama.cpp 服务器，也可以是远程 API（如 OpenRouter）

# 本地 llama.cpp 示例:
# LOCAL_MODEL_URL=http://10.0.0.114:8080/v1
# LOCAL_MODEL_KEY=any
# LOCAL_MODEL_ID=your-model-name.gguf

# OpenRouter 示例:
LOCAL_MODEL_URL=https://openrouter.ai/api/v1
LOCAL_MODEL_KEY=your_openrouter_api_key_here
LOCAL_MODEL_ID=z-ai/glm-4.5-air:free

# ============================================================================
# OpenRouter 远端模型配置 (OpenRouter Remote Model Configuration)
# ============================================================================
# 用于测试执行页面的远端模型配置
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# ============================================================================
# LiteLLM 配置 (LiteLLM Configuration)
# ============================================================================
LITELLM_API_KEY=123456
LITELLM_API_URL=http://127.0.0.1:4000

# ============================================================================
# Qwen 配置 (Qwen Configuration)
# ============================================================================
# 阿里云 DashScope API 配置
# 用于测试执行页面的 Qwen 模型配置
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_ID=qwen3.5-plus

# ============================================================================
# NVIDIA 配置 (NVIDIA Configuration)
# ============================================================================
# NVIDIA API 配置
# 用于测试执行页面的 NVIDIA 模型配置
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_ID=z-ai/glm4.7
